<Window x:Class="GameOfLife.WPF.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:GameOfLife.WPF"
        mc:Ignorable="d"
        Title="Conway's Game of Life" Height="700" Width="900">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"></RowDefinition>
            <RowDefinition/>
            <RowDefinition Height="Auto"></RowDefinition>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="10">
            <Button Content="Start" Width ="110" Height="45" Margin="5" Click="StartClick"/>
            <Button Content="Stop" Width ="110" Height="45" Margin="5"/>
            <Button Content="Reset" Width ="110" Height="45" Margin="5"/>

            <Separator Width="20" Visibility="Hidden"></Separator>

            <TextBlock Text="Interval (ms)" VerticalAlignment="Center" Margin="15 0 5 0"></TextBlock>
            <TextBox Text="200" VerticalContentAlignment="Center" Height="20" Margin="50"></TextBox>
            
        </StackPanel>
        <Border Grid.Row="1" BorderBrush="DarkGray" BorderThickness="2" Margin="10" Background="White">
            <UniformGrid x:Name="gameGrid" Rows="20" Columns="30" Background="LightCoral"/>
        </Border>
        <TextBlock Grid.Row="2" Margin="13" FontSize ="20" FontWeight="Bold" Text="Generation: 1"/>
    </Grid>
</Window>
